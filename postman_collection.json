{
  "info": {
    "_postman_id": "mini-task-api",
    "name": "Mini Task Management System",
    "description": "RESTful API collection for JWT-secured task management with RBAC (ADMIN, USER)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.user@example.com\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Register new user. Default role is USER."
          },
          "response": []
        },
        {
          "name": "Login User (set access_token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body && body.token) {",
                  "  pm.collectionVariables.set('access_token', body.token);",
                  "}",
                  "if (body && body.userId) {",
                  "  pm.collectionVariables.set('user_id', body.userId);",
                  "}",
                  "if (body && body.role) {",
                  "  pm.collectionVariables.set('user_role', body.role);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Login user and auto-store JWT into {{access_token}}."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tasks (USER or ADMIN)",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Complete project report\",\n  \"description\": \"Finish and submit the Q1 project report\",\n  \"status\": \"TODO\",\n  \"priority\": \"HIGH\",\n  \"dueDate\": \"2026-03-31T17:00:00\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tasks"
              ]
            },
            "description": "Create a new task (requires USER or ADMIN role)."
          },
          "response": []
        },
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks?page=0&size=10&sortBy=dueDate&sortDirection=asc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tasks"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sortBy",
                  "value": "dueDate"
                },
                {
                  "key": "sortDirection",
                  "value": "asc"
                }
              ]
            },
            "description": "Get all tasks with pagination and sorting (requires USER or ADMIN role)."
          },
          "response": []
        },
        {
          "name": "Get Tasks by Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks?status=TODO&page=0&size=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tasks"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "TODO"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "Get tasks filtered by status (requires USER or ADMIN role)."
          },
          "response": []
        },
        {
          "name": "Get Tasks by Priority",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks?priority=HIGH&page=0&size=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tasks"
              ],
              "query": [
                {
                  "key": "priority",
                  "value": "HIGH"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "Get tasks filtered by priority (requires USER or ADMIN role)."
          },
          "response": []
        },
        {
          "name": "Get Tasks by Status and Priority",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks?status=TODO&priority=HIGH&page=0&size=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tasks"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "TODO"
                },
                {
                  "key": "priority",
                  "value": "HIGH"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "Get tasks filtered by both status and priority (requires USER or ADMIN role)."
          },
          "response": []
        },
        {
          "name": "Get Single Task",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tasks",
                "1"
              ]
            },
            "description": "Get a single task by ID (requires USER or ADMIN role)."
          },
          "response": []
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated task title\",\n  \"description\": \"Updated description\",\n  \"status\": \"IN_PROGRESS\",\n  \"priority\": \"MEDIUM\",\n  \"dueDate\": \"2026-04-15T17:00:00\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tasks",
                "1"
              ]
            },
            "description": "Update an existing task (requires USER or ADMIN role)."
          },
          "response": []
        },
        {
          "name": "Mark Task as Completed",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks/1/complete",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tasks",
                "1",
                "complete"
              ]
            },
            "description": "Mark a task as completed (requires USER or ADMIN role)."
          },
          "response": []
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/tasks/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tasks",
                "1"
              ]
            },
            "description": "Delete a task (requires USER or ADMIN role)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin Users (ADMIN only)",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Alice\",\n  \"lastName\": \"Admin\",\n  \"email\": \"alice.admin@example.com\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "users",
                "register"
              ]
            },
            "description": "Register a new admin user (ADMIN role required)."
          },
          "response": []
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users?page=0&size=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "users"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "Get all users (ADMIN role required)."
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "users",
                "1"
              ]
            },
            "description": "Get a single user by ID (ADMIN role required)."
          },
          "response": []
        },
        {
          "name": "Change User Role",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/1/role?role=ADMIN",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "users",
                "1",
                "role"
              ],
              "query": [
                {
                  "key": "role",
                  "value": "ADMIN"
                }
              ]
            },
            "description": "Promote/demote a user role (ADMIN role required)."
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/2",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "users",
                "2"
              ]
            },
            "description": "Delete user (ADMIN role required)."
          },
          "response": []
        },
        {
          "name": "Get Current Admin Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "users",
                "me"
              ]
            },
            "description": "Get authenticated admin profile (ADMIN role required)."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api/v1",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_role",
      "value": "",
      "type": "string"
    }
  ]
}
